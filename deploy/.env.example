# Iron-Veil Demo — environment variables
# Copy to .env and fill in values before running.

# ---------------------------------------------------------------------------
# Data lake S3 sink (SIG-009) — passed to Signet at startup
# These are set on the Signet service, not drone-sim.
# For local dev with MinIO: use the values below as-is after starting the
# datalake profile: docker compose --profile datalake up -d
# ---------------------------------------------------------------------------
DATA_LAKE_S3_ENDPOINT=http://localhost:9000
DATA_LAKE_S3_ACCESS_KEY=minioadmin
DATA_LAKE_S3_SECRET_KEY=minioadmin
DATA_LAKE_S3_BUCKET=iron-veil-fmv

# ---------------------------------------------------------------------------
# MinIO (local dev data lake only)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
